---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="settl - Terminal Hex Settlement Game with AI Players"
  description="A terminal hex settlement game where LLMs play via tool calling. Watch Claude, GPT, and Gemini negotiate trades and compete -- all in your terminal."
>
  <Nav />

  <main>
  <!-- Hero Section -->
  <section class="relative pt-32 pb-8 px-6 hero-glow hero-gradient-animated">
    <div class="max-w-6xl mx-auto text-left">
      <div class="mb-8">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold mb-6 tracking-tight font-display">
          <span class="text-gradient">settl</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-100 max-w-2xl leading-relaxed">
          Terminal hex settlement game with AI players
        </p>
      </div>

      <p class="text-lg text-gray-100 max-w-3xl mb-12 leading-relaxed">
        Play against <span class="text-white font-medium">Claude</span>, <span class="text-white font-medium">GPT</span>, and <span class="text-white font-medium">Gemini</span> in a hex-based resource trading and building game.
        <span class="text-gray-400">Runs locally with llamafile. No API keys needed. Built with Rust and ratatui.</span>
      </p>

      <!-- Install block -->
      <div class="max-w-2xl mb-8">
        <div class="code-block rounded-xl p-1">
          <div class="flex items-center gap-2 px-4 py-2 border-b border-surface-700/50">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <div class="px-5 py-4 font-mono text-sm md:text-base flex items-center justify-between gap-4">
            <code class="text-gray-100 overflow-x-auto">
              <span class="text-gray-500 select-none">$ </span><span class="text-brand-400">git clone</span> https://github.com/Brake-Labs/settl.git && <span class="text-brand-400">cd</span> settl && <span class="text-brand-400">cargo</span> run
            </code>
            <button onclick="copyCommand('git clone https://github.com/Brake-Labs/settl.git && cd settl && cargo run', this)" class="install-copy-btn text-gray-500 hover:text-brand-400 transition-colors p-2 rounded-lg hover:bg-surface-700/50 flex-shrink-0" title="Copy to clipboard">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-start mb-16">
        <a href={`${base}/docs/getting-started/`} class="btn-primary text-base px-8 py-3.5 inline-flex items-center justify-center">
          Get Started
        </a>
        <a href="https://github.com/Brake-Labs/settl" target="_blank" rel="noopener" class="btn-secondary text-base px-8 py-3.5 group inline-flex items-center justify-center gap-2" title="Star on GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <svg class="w-4 h-4 text-brand-400 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/></svg>
          <span id="star-count">...</span> Stars
        </a>
      </div>
    </div>
  </section>

  <!-- Feature Grid -->
  <section class="py-12 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="mb-8">
        <span class="font-mono text-xs uppercase tracking-widest text-brand-600">Features</span>
      </div>
      <div class="grid lg:grid-cols-[1.4fr_1fr] gap-6">
        <!-- Featured card -->
        <div class="lg:row-span-2 delay-100">
          <div class="feature-card feature-tint-brand rounded-2xl p-10 animate-on-scroll h-full flex flex-col justify-center">
            <h3 class="text-2xl font-semibold mb-4 font-display flex items-center gap-3">
              <svg class="w-6 h-6 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Play or Spectate
            </h3>
            <p class="text-gray-100 leading-relaxed text-lg">Take on AI opponents or watch Claude, GPT, and Gemini battle it out in your terminal. Full TUI with hex board, resource tracking, and AI reasoning display.</p>
          </div>
        </div>
        <!-- Supporting cards -->
        <div class="delay-200">
          <div class="feature-card feature-tint-accent rounded-2xl p-6 animate-on-scroll">
            <h3 class="text-lg font-semibold mb-2 font-display flex items-center gap-2.5">
              <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/>
              </svg>
              Local AI
            </h3>
            <p class="text-gray-100 leading-relaxed text-sm">Runs entirely locally with llamafile. No API keys, no internet, no cloud. Download once and play offline.</p>
          </div>
        </div>
        <div class="delay-300">
          <div class="feature-card rounded-2xl p-6 animate-on-scroll">
            <h3 class="text-lg font-semibold mb-2 font-display flex items-center gap-2.5">
              <svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              AI Personalities
            </h3>
            <p class="text-gray-100 leading-relaxed text-sm">Aggressive traders, grudge holders, chaos agents. Five built-in personalities plus custom TOML configs.</p>
          </div>
        </div>
        <div class="delay-200">
          <div class="feature-card rounded-2xl p-6 animate-on-scroll">
            <h3 class="text-lg font-semibold mb-2 font-display flex items-center gap-2.5">
              <svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              Full Game Rules
            </h3>
            <p class="text-gray-100 leading-relaxed text-sm">Settlements, cities, roads, robber, development cards, trading, Longest Road, Largest Army. Complete hex settlement game.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  </main>

  <Footer />
</Base>
